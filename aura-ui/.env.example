# Copy to `.env` in this folder and set your machine's LAN IP for physical devices / APK builds.
# Find LAN IP (Linux): hostname -I | awk '{print $1}'
#
# Phone and laptop must be on the same Wi‑Fi. Backends must listen on 0.0.0.0 (see root README).

EXPO_PUBLIC_API_BASE_URL=http://192.168.8.105:8080
EXPO_PUBLIC_AI_AGENT_BASE_URL=http://192.168.8.105:8001
